# Port the Express server listens on
API_PORT=3001

# Secret key n8n must send in the x-dashboard-api-key header when pushing data
DASHBOARD_API_KEY=change-me-to-a-strong-secret

# Paths to the JSON data files (relative to the project root)
TENANT_LINKS_FILE=./data/tenant-links.json
REQUESTS_DATA_FILE=./data/requests.json
SETTINGS_FILE=./data/settings.json

# Per-client n8n webhook URLs are stored in data/tenant-links.json (n8n_webhook_url field)
# No global webhook needed — each client fires to their own n8n workflow

# Frontend env vars (used at Vite build time — prefix with VITE_)
VITE_ENABLE_WEBHOOKS=true
VITE_API_BASE_URL=
